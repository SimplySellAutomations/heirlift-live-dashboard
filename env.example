const jsforce = require('jsforce');

module.exports = async (req, res) => {
  res.setHeader('Access-Control-Allow-Origin', '*');
  res.setHeader('Content-Type', 'application/json');
  res.setHeader('Cache-Control', 'no-store');

  const conn = new jsforce.Connection({ loginUrl: 'https://login.salesforce.com' });

  try {
    await conn.login(
      process.env.SF_USERNAME,
      process.env.SF_PASSWORD + (process.env.SF_TOKEN || '')
    );

    const period = req.query.period || 'today';
    let leadFilter, actFilter;
    if (period === 'today')       { leadFilter = 'LastModifiedDate = TODAY';        actFilter = 'CreatedDate = TODAY'; }
    else if (period === 'week')   { leadFilter = 'LastModifiedDate >= THIS_WEEK';   actFilter = 'CreatedDate >= THIS_WEEK'; }
    else if (period === 'month')  { leadFilter = 'LastModifiedDate >= THIS_MONTH';  actFilter = 'CreatedDate >= THIS_MONTH'; }
    else if (period === 'custom' && req.query.from && req.query.to) {
      leadFilter = `LastModifiedDate >= ${req.query.from}T00:00:00Z AND LastModifiedDate <= ${req.query.to}T23:59:59Z`;
      actFilter  = `CreatedDate >= ${req.query.from}T00:00:00Z AND CreatedDate <= ${req.query.to}T23:59:59Z`;
    } else { leadFilter = 'LastModifiedDate = TODAY'; actFilter = 'CreatedDate = TODAY'; }

    const [leadsRes, oppsRes, callsRes, textsRes, callDetailRes, textDetailRes] = await Promise.all([
      conn.query(`SELECT Id, Name, Status, Owner.Name, LastModifiedDate, Driver_Status__c, Letters_Action_Type__c, Date_Mailed__c FROM Lead WHERE ${leadFilter} ORDER BY LastModifiedDate DESC LIMIT 500`),
      conn.query(`SELECT Id, Name, StageName, Owner.Name, CloseDate FROM Opportunity ORDER BY LastModifiedDate DESC LIMIT 200`),
      conn.query(`SELECT Owner.Name, COUNT(Id) cnt FROM ccra__Call_History__c WHERE ${actFilter} GROUP BY Owner.Name ORDER BY COUNT(Id) DESC LIMIT 20`),
      conn.query(`SELECT Owner.Name, COUNT(Id) cnt FROM sra__Message_History__c WHERE ${actFilter} AND Owner.Name != 'Automated Process' GROUP BY Owner.Name ORDER BY COUNT(Id) DESC LIMIT 20`),
      conn.query(`SELECT Id, Owner.Name, ccra__Lead__c, ccra__Duration__c, CreatedDate FROM ccra__Call_History__c WHERE ${actFilter} ORDER BY Owner.Name, CreatedDate DESC LIMIT 200`),
      conn.query(`SELECT Id, Owner.Name, sra__Lead__c, CreatedDate FROM sra__Message_History__c WHERE ${actFilter} AND Owner.Name != 'Automated Process' ORDER BY Owner.Name, CreatedDate DESC LIMIT 200`),
    ]);

    const leadIds = [...new Set([
      ...callDetailRes.records.map(r => r.ccra__Lead__c).filter(Boolean),
      ...textDetailRes.records.map(r => r.sra__Lead__c).filter(Boolean),
    ])];
    let leadNames = {};
    if (leadIds.length > 0) {
      const lnRes = await conn.query(`SELECT Id, Name FROM Lead WHERE Id IN (${leadIds.map(id=>`'${id}'`).join(',')})`);
      lnRes.records.forEach(r => { leadNames[r.Id] = r.Name; });
    }

    const callDetail = {}, textDetail = {};
    callDetailRes.records.forEach(r => {
      const owner = r.Owner?.Name; if (!owner) return;
      if (!callDetail[owner]) callDetail[owner] = [];
      const t = new Date(r.CreatedDate);
      callDetail[owner].push({ lead: leadNames[r.ccra__Lead__c]||'No lead linked', leadId: r.ccra__Lead__c||null, duration: r.ccra__Duration__c, time: t.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',timeZone:'America/Los_Angeles'}) });
    });
    textDetailRes.records.forEach(r => {
      const owner = r.Owner?.Name; if (!owner) return;
      if (!textDetail[owner]) textDetail[owner] = [];
      const t = new Date(r.CreatedDate);
      textDetail[owner].push({ lead: leadNames[r.sra__Lead__c]||'No lead linked', leadId: r.sra__Lead__c||null, time: t.toLocaleTimeString('en-US',{hour:'numeric',minute:'2-digit',timeZone:'America/Los_Angeles'}) });
    });

    const calls = {}, texts = {};
    callsRes.records.forEach(r => { calls[r.Name] = Number(r.cnt||r.expr0||0); });
    textsRes.records.forEach(r => { texts[r.Name] = Number(r.cnt||r.expr0||0); });

    res.status(200).json({ ok:true, period, generatedAt: new Date().toISOString(), leads: leadsRes.records, opps: oppsRes.records, activity: { calls, texts, callDetail, textDetail } });

  } catch(err) {
    res.status(500).json({ ok:false, error: err.message });
  }
};
